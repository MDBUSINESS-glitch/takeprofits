<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TakeTips IA — Inteligência Artificial para Traders</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    :root {
      --green: #00e676;
      --green-dark: #00b85c;
      --green-glow: rgba(0,230,118,0.18);
      --bg: #060c0a;
      --bg2: #0b1510;
      --bg3: #0f1e17;
      --card: #101a14;
      --border: rgba(0,230,118,0.15);
      --text: #e8f5ee;
      --muted: #7a9e8a;
      --gold: #ffd600;
    }

    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    /* ─── NAV ─── */
    nav {
      position: absolute; top:0; width:100%; z-index:100;
      background: rgba(6,12,10,0.2) !important;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding: 16px 40px;
      display: flex; align-items:center; justify-content:space-between;
    }
    .logo {
      font-size: 1.4rem; font-weight: 800; letter-spacing: -0.5px;
      color: var(--green);
      display:flex; align-items:center; gap:8px;
    }
    .logo span { color: var(--text); }
    .nav-actions { display:flex; align-items:center; gap:12px; }
    .nav-login {
      color: var(--green); background: transparent;
      border: 1.5px solid var(--green); padding: 9px 20px; border-radius:8px;
      font-weight: 600; font-size: 0.9rem; cursor:pointer;
      text-decoration:none; transition: all 0.2s;
    }
    .nav-login:hover { background: var(--green-glow); }
    .nav-cta {
      background: var(--green); color: #060c0a;
      border:none; padding: 10px 24px; border-radius:8px;
      font-weight: 700; font-size: 0.9rem; cursor:pointer;
      text-decoration:none; transition: all 0.2s;
    }
    .nav-cta:hover { background: var(--green-dark); transform:scale(1.03); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction:column; align-items:center; justify-content:center;
      text-align: center;
      padding: 140px 20px 60px;
      position: relative;
      overflow: hidden;
      background: var(--bg);
    }
    .hero-video {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      z-index: 0;
      pointer-events: none;
    }
    .hero::before {
      content:'';
      position:absolute; inset: 0;
      background: linear-gradient(180deg, rgba(6,12,10,0.5) 0%, rgba(6,12,10,0.95) 100%);
      z-index: 1;
      pointer-events:none;
    }
    .hero > *:not(.hero-video) {
      position: relative;
      z-index: 2;
    }
    .hero-badge {
      display:inline-flex; align-items:center; gap:8px;
      background: rgba(0,0,0,0.4); border: 1px solid var(--green);
      color: var(--green); border-radius:100px;
      padding: 8px 18px; font-size:0.82rem; font-weight:600;
      margin-bottom: 18px; letter-spacing:0.5px;
      backdrop-filter: blur(10px);
    }
    .hero-badge::before { content:'●'; font-size:0.6rem; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    .hero h1 {
      font-size: clamp(2.4rem, 6vw, 4.8rem);
      font-weight: 900; line-height: 1.1;
      letter-spacing: -2px;
      max-width: 860px;
      margin-bottom: 16px;
      text-shadow: 0 4px 20px rgba(0,0,0,0.8);
    }
    .hero h1 .highlight {
      color: var(--green);
      position:relative;
    }
    .hero p {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: #e8f5ee; line-height:1.7;
      max-width: 640px; margin-bottom: 28px;
      text-shadow: 0 2px 10px rgba(0,0,0,0.8);
      font-weight: 500;
    }
    .hero-action-area { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 400px; }
    .hero-btns { display:flex; gap:16px; flex-wrap:wrap; justify-content:center; width: 100%; }
    .hero-risk-free { font-size: 0.82rem; color: var(--muted); margin-top: 12px; font-weight: 500; text-align: center; }
    .btn-primary {
      background: var(--green); color: #060c0a;
      padding: 16px 40px; border-radius:10px; border:none;
      font-size: 1.05rem; font-weight: 800; cursor:pointer;
      text-decoration:none; transition:all 0.2s;
      box-shadow: 0 0 30px rgba(0,230,118,0.3);
    }
    .btn-primary:hover { transform:translateY(-2px); box-shadow: 0 0 50px rgba(0,230,118,0.45); }
    .btn-secondary {
      background: transparent; color: var(--text);
      padding: 16px 36px; border-radius:10px;
      border: 1px solid var(--border);
      font-size: 1rem; font-weight: 600; cursor:pointer;
      text-decoration:none; transition:all 0.2s;
    }
    .btn-secondary:hover { border-color: var(--green); color: var(--green); }

    .hero-stats {
      display: flex; gap:48px; margin-top:60px; flex-wrap:wrap; justify-content:center;
    }
    .stat { text-align:center; }
    .stat-num { font-size:2rem; font-weight:800; color:var(--green); }
    .stat-label { font-size:0.82rem; color:var(--muted); margin-top:4px; }

    /* ─── SECTIONS ─── */
    section { padding: 100px 20px; }
    .container { max-width:1100px; margin:0 auto; }
    .section-tag {
      display:inline-block; color:var(--green);
      font-size:0.78rem; font-weight:700; letter-spacing:2px;
      text-transform:uppercase; margin-bottom:14px;
    }
    h2 {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 800; letter-spacing:-1px; line-height:1.15;
      margin-bottom: 16px;
    }
    .subtitle {
      color:var(--muted); font-size:1.1rem; line-height:1.7;
      max-width:580px; margin-bottom:60px;
    }

    /* ─── PROBLEM ─── */
    .problem-bg { background: var(--bg2); padding-bottom: 140px; }
    .problem-grid {
      display:grid; grid-template-columns:repeat(3,1fr); gap:24px;
    }
    .problem-card {
      background: var(--card); border: 1px solid rgba(255,80,80,0.15);
      border-radius:16px; padding:28px;
    }
    .problem-icon { font-size:2rem; margin-bottom:12px; }
    .problem-card h3 { font-size:1rem; font-weight:700; margin-bottom:8px; color:#ff6b6b; }
    .problem-card p { color:var(--muted); font-size:0.9rem; line-height:1.6; }

    /* ─── HOW IT WORKS ─── */
    .steps {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:32px;
    }
    .step {
      text-align:center; padding:32px 24px;
      background:var(--card); border:1px solid var(--border); border-radius:20px;
      position:relative; transition:all 0.3s;
    }
    .step:hover { border-color:var(--green); transform:translateY(-4px); box-shadow:0 12px 40px var(--green-glow); }
    .step-num {
      width:52px; height:52px; border-radius:50%;
      background: var(--green-glow); border:2px solid var(--green);
      color:var(--green); font-size:1.2rem; font-weight:800;
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 20px;
    }
    .step-icon { font-size:2.2rem; margin-bottom:16px; }
    .step h3 { font-size:1.05rem; font-weight:700; margin-bottom:10px; }
    .step p { color:var(--muted); font-size:0.88rem; line-height:1.65; }

    /* ─── FEATURES ─── */
    .features-bg { background: var(--bg2); }
    .features-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:24px;
    }
    .feature-card {
      background:var(--card); border:1px solid var(--border); border-radius:16px; padding:28px;
      transition:all 0.3s;
    }
    .feature-card:hover { border-color:var(--green); box-shadow:0 8px 32px var(--green-glow); }
    .feature-icon {
      width:48px; height:48px; border-radius:12px;
      background:var(--green-glow); border:1px solid var(--border);
      display:flex; align-items:center; justify-content:center;
      font-size:1.5rem; margin-bottom:18px;
    }
    .feature-card h3 { font-size:1rem; font-weight:700; margin-bottom:10px; }
    .feature-card p { color:var(--muted); font-size:0.88rem; line-height:1.65; }

    /* ─── TRADER SECTION ─── */
    .trader-section {
      background: linear-gradient(135deg, var(--bg3) 0%, var(--bg2) 100%);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .trader-inner {
      display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;
    }
    @media(max-width:768px){ .trader-inner { grid-template-columns:1fr; } }
    .trader-avatar {
      width: 100%; max-width: 380px; aspect-ratio: 1; border-radius:16px;
      border: 2px solid var(--green);
      overflow:hidden; margin-bottom:24px;
      box-shadow: 0 0 40px rgba(0,255,136,0.3);
    }
    .trader-avatar img {
      width:100%; height:100%; object-fit:cover; object-position:center top;
      display:block;
    }
    .trader-badges { display:flex; flex-wrap:wrap; gap:10px; margin-top:20px; }
    .badge {
      background:var(--green-glow); border:1px solid var(--border);
      color:var(--green); padding:6px 14px; border-radius:100px;
      font-size:0.78rem; font-weight:600;
    }
    .trader-quote {
      font-size:1.5rem; font-weight:300; line-height:1.6;
      color:var(--text); margin-bottom:20px;
      border-left:3px solid var(--green); padding-left:20px;
    }
    .trader-quote strong { font-weight:700; color:var(--green); }

    /* ─── SOCIAL PROOF ─── */
    .proof-bg { background: var(--bg3); }
    .proof-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:20px;
      margin-top: 48px;
    }
    .proof-card {
      background:var(--card); border:1px solid var(--border); border-radius:16px;
      padding:28px 24px; text-align:center;
    }
    .proof-number { font-size:2.6rem; font-weight:900; color:var(--green); letter-spacing:-2px; }
    .proof-label { font-size:0.88rem; color:var(--muted); margin-top:6px; line-height:1.5; }

    /* ─── PRICING ─── */
    .pricing-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
      gap:24px; align-items:start;
    }
    .pricing-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:20px; padding:36px; position:relative;
      transition:all 0.3s;
    }
    .pricing-card:hover { transform:translateY(-4px); box-shadow:0 16px 48px var(--green-glow); }
    .pricing-card.popular {
      border-color:var(--green);
      box-shadow: 0 0 40px var(--green-glow);
      transform:scale(1.03);
    }
    .popular-tag {
      position:absolute; top:-14px; left:50%; transform:translateX(-50%);
      background:var(--green); color:#060c0a;
      padding:6px 20px; border-radius:100px;
      font-size:0.78rem; font-weight:800; white-space:nowrap;
      letter-spacing:0.5px;
    }
    .plan-name { font-size:1.1rem; font-weight:700; color:var(--muted); margin-bottom:8px; }
    .plan-price {
      font-size:3rem; font-weight:900; letter-spacing:-2px;
      color:var(--text); line-height:1;
    }
    .plan-price sup { font-size:1.2rem; font-weight:600; vertical-align:top; margin-top:8px; display:inline-block; }
    .plan-period { color:var(--muted); font-size:0.9rem; margin-bottom:28px; }
    .plan-divider { border:none; border-top:1px solid var(--border); margin:24px 0; }
    .plan-features { list-style:none; display:flex; flex-direction:column; gap:12px; margin-bottom:32px; }
    .plan-features li {
      display:flex; align-items:flex-start; gap:10px;
      font-size:0.9rem; color:var(--text); line-height:1.5;
    }
    .plan-features li .check { color:var(--green); font-size:1rem; flex-shrink:0; margin-top:1px; }
    .plan-features li .x { color:#ff6b6b; font-size:1rem; flex-shrink:0; margin-top:1px; }
    .plan-btn {
      width:100%; padding:14px; border-radius:10px; border:none;
      font-size:0.98rem; font-weight:700; cursor:pointer; transition:all 0.2s;
      text-decoration:none; display:block; text-align:center;
    }
    .plan-btn-primary { background:var(--green); color:#060c0a; }
    .plan-btn-primary:hover { background:var(--green-dark); transform:translateY(-1px); }
    .plan-btn-outline { background:transparent; color:var(--green); border:1px solid var(--green); }
    .plan-btn-outline:hover { background:var(--green-glow); }

    /* ─── GUARANTEE ─── */
    .guarantee-box {
      background:var(--card); border:1px solid var(--green);
      border-radius:20px; padding:48px; text-align:center;
      max-width:700px; margin:0 auto;
    }
    .guarantee-icon { font-size:4rem; margin-bottom:20px; }
    .guarantee-box h3 { font-size:1.8rem; font-weight:800; margin-bottom:12px; }
    .guarantee-box p { color:var(--muted); line-height:1.7; font-size:1rem; }

    /* ─── FAQ ─── */
    .faq-bg { background: var(--bg2); }
    .faq-list { max-width:720px; margin:0 auto; display:flex; flex-direction:column; gap:12px; }
    .faq-item {
      background:var(--card); border:1px solid var(--border);
      border-radius:12px; overflow:hidden;
    }
    .faq-q {
      padding:20px 24px; font-weight:600; font-size:0.98rem;
      cursor:pointer; display:flex; justify-content:space-between; align-items:center;
      transition:color 0.2s; user-select:none;
    }
    .faq-q:hover { color:var(--green); }
    .faq-q .faq-icon { color:var(--green); font-size:1.2rem; flex-shrink:0; transition:transform 0.3s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-a {
      max-height:0; overflow:hidden; transition:max-height 0.35s ease, padding 0.25s ease;
      padding:0 24px; color:var(--muted); font-size:0.9rem; line-height:1.7;
    }
    .faq-item.open .faq-a { max-height:300px; padding:0 24px 20px; }

    /* ─── CTA FINAL ─── */
    .cta-final {
      text-align:center; padding:120px 20px;
      background: linear-gradient(180deg, var(--bg) 0%, var(--bg3) 50%, var(--bg) 100%);
      position:relative; overflow:hidden;
    }
    .cta-final::before {
      content:'';
      position:absolute; bottom:-300px; left:50%; transform:translateX(-50%);
      width:800px; height:800px;
      background: radial-gradient(circle, rgba(0,230,118,0.07) 0%, transparent 70%);
    }
    .cta-final h2 { max-width:700px; margin:0 auto 20px; }
    .cta-final p { color:var(--muted); max-width:520px; margin:0 auto 40px; font-size:1.05rem; line-height:1.7; }

    /* ─── FOOTER ─── */
    footer {
      background:var(--bg2); border-top:1px solid var(--border);
      padding:40px 20px; text-align:center;
    }
    footer .footer-logo { font-size:1.3rem; font-weight:800; color:var(--green); margin-bottom:12px; }
    footer p { color:var(--muted); font-size:0.82rem; line-height:1.7; }
    footer a { color:var(--muted); text-decoration:none; }
    footer a:hover { color:var(--green); }

    /* ─── TICKER ─── */
    .ticker-wrap {
      position: absolute; top: 74px; width: 100%; z-index: 90;
      background: rgba(0,230,118,0.06); border-top:1px solid rgba(255,255,255,0.05); border-bottom:1px solid rgba(255,255,255,0.05);
      padding:12px 0; overflow:hidden; white-space:nowrap;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    }
    .ticker {
      display:inline-block;
      animation: ticker 30s linear infinite;
    }
    .ticker span {
      margin:0 32px; font-size:0.82rem; font-weight:600; color:var(--muted);
    }
    .ticker span.up { color:var(--green); }
    .ticker span.down { color:#ff6b6b; }
    @keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }

    /* ─── MODAL ─── */
    .modal-overlay {
      display:none; position:fixed; inset:0; z-index:999;
      background:rgba(0,0,0,0.85); backdrop-filter:blur(6px);
      align-items:center; justify-content:center;
    }
    .modal-overlay.active { display:flex; }
    .modal-box {
      background:var(--card); border:1px solid var(--green);
      border-radius:20px; padding:40px; max-width:440px; width:90%;
      text-align:center; position:relative;
    }
    .modal-box h3 { font-size:1.5rem; font-weight:800; margin-bottom:10px; }
    .modal-box p { color:var(--muted); margin-bottom:28px; font-size:0.95rem; line-height:1.6; }
    .modal-close {
      position:absolute; top:16px; right:20px;
      background:none; border:none; color:var(--muted);
      font-size:1.5rem; cursor:pointer; line-height:1;
    }
    .modal-close:hover { color:var(--text); }
    .modal-plan-name {
      display:inline-block; background:var(--green-glow); border:1px solid var(--green);
      color:var(--green); padding:4px 16px; border-radius:100px;
      font-size:0.8rem; font-weight:700; margin-bottom:20px;
    }
    .modal-price { font-size:2.8rem; font-weight:900; color:var(--green); margin-bottom:4px; }
    .modal-period { color:var(--muted); font-size:0.85rem; margin-bottom:28px; }
    .modal-btn {
      display:block; width:100%; padding:14px; border-radius:10px;
      background:var(--green); color:#060c0a; border:none;
      font-size:1rem; font-weight:800; cursor:pointer; text-decoration:none;
      transition:all 0.2s; margin-bottom:12px;
    }
    .modal-btn:hover { background:var(--green-dark); }
    .modal-secure { font-size:0.78rem; color:var(--muted); }

    /* ─── RESPONSIVE ─── */
    @media(max-width:768px) {
      .trader-inner { grid-template-columns:1fr; }
      .problem-grid { grid-template-columns:1fr; }
      section { padding:60px 20px; }
      .problem-bg { padding-bottom:60px; }
      .subtitle { margin-bottom:36px; }
    }

    @media(max-width:600px) {
      nav { padding:10px 16px; }
      .nav-cta { white-space:nowrap; font-size:0.8rem; padding:8px 14px; }
      .nav-login { font-size:0.8rem; padding:8px 14px; }
      .hero { padding:140px 16px 24px; min-height: auto; }
      .hero h1 { letter-spacing:-1px; font-size: 2.2rem; }
      .hero p { margin-bottom:24px; font-size: 0.95rem; line-height: 1.5; }
      .hero-action-area { margin-top: 10px; }
      .hero-btns { flex-direction:column; align-items:stretch; gap:12px; width: 100%; }
      .btn-primary { padding:14px 24px; text-align:center; }
      .btn-secondary { padding:14px 24px; text-align:center; }
      .hero-stats { margin-top:32px; gap:20px; }
      .stat-num { font-size:1.6rem; }
      .pricing-card.popular { transform:scale(1); }
      .ticker-wrap { top: 62px; }
      .ticker span { margin:0 18px; font-size:0.78rem; }
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════
     ⚙️  PAYMENT CONFIGURATION
     Replace the URLs below with your real payment links
     (Stripe, Hotmart, Kiwify, Gumroad, etc.)
     ═══════════════════════════════════════════════ -->
<script>
  var PAYMENT_LINKS = {
    starter:    'https://buy.stripe.com/YOUR_STARTER_LINK',   // ← replace
    pro:        'https://buy.stripe.com/YOUR_PRO_LINK',       // ← replace
    enterprise: 'https://buy.stripe.com/YOUR_ENTERPRISE_LINK' // ← replace
  };

  var LOGIN_URL  = 'https://app.taketips.ai/login'; // ← replace with your app URL
  var TERMS_URL  = '#';                              // ← replace with your terms page

  var PLANS = {
    starter:    { name:'Starter',    price:'$12', period:'/month' },
    pro:        { name:'Pro',        price:'$19', period:'/month' },
    enterprise: { name:'Enterprise', price:'$37', period:'/month' }
  };

  function checkout(plan) {
    var url = PAYMENT_LINKS[plan];
    if (!url || url.indexOf('YOUR_') !== -1) {
      alert('⚙️ Payment link not configured yet.\n\nOpen index.html and set your PAYMENT_LINKS at the top of the <script> section.');
      return;
    }
    window.location.href = url;
  }

  function openModal(plan) {
    var p = PLANS[plan];
    document.getElementById('modal-plan').textContent  = p.name;
    document.getElementById('modal-price').textContent = p.price;
    document.getElementById('modal-period').textContent = p.period;
    document.getElementById('modal-confirm').onclick = function(){ checkout(plan); };
    document.getElementById('checkout-modal').classList.add('active');
  }

  function closeModal() {
    document.getElementById('checkout-modal').classList.remove('active');
  }

  document.addEventListener('DOMContentLoaded', function() {
    // FAQ accordion
    document.querySelectorAll('.faq-q').forEach(function(q) {
      q.addEventListener('click', function() {
        var item = this.closest('.faq-item');
        var isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(function(i){ i.classList.remove('open'); });
        if (!isOpen) item.classList.add('open');
      });
    });
    // Close modal on overlay click
    document.getElementById('checkout-modal').addEventListener('click', function(e){
      if (e.target === this) closeModal();
    });
  });
</script>

<!-- NAV -->
<nav>
